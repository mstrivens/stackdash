{
  "name": "stackdash",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/frontend/App.tsx --outdir=dist --minify && cp src/frontend/index.html dist/ && cp src/frontend/styles.css dist/",
    "deploy": "npm run build && wrangler deploy",
    "cf:dev": "wrangler dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "hono": "^4.12.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.73.0"
  }
}
